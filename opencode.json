{
  "$schema": "https://opencode.ai",
  "project": {
    "name": "starsector-opencode-modding-framework",
    "languages": ["java", "kotlin"],
    "target_jvm_version": "1.7",
    "detect_from_extension": true
  },
  "agent": {
    "rules_files": ["AGENTS.md", "RULES.md"],
    "index_dependencies": true,
    "indexing_patterns": [
      "src/**/*.java",
      "src/**/*.kt",
      "jars/**/*.jar",
      ".idea/libraries/*.xml"
    ]
  },
  "plugin": [
    "opencode-brain"
  ]
  "references": {
    "starsector_core": {
      "path": ".idea/libraries/starfarer_api.xml",
      "description": "Fallback pointer to map the Starsector engine API library profile generated by IntelliJ"
    }
  }
}
